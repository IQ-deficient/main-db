# Root credentials used by the database servers and scripts.
ADMIN_DB_USERNAME=root
ADMIN_DB_PASSWORD=

# Host to bind database ports to. Use 127.0.0.1: to listen only on localhost (default). Leave empty to listen on all interfaces (e.g. for LAN access).
PORT_HOST_PREFIX=127.0.0.1:

# Suffix appended to container names. Change to avoid conflicts between environments.
DB_NAME_SUFFIX=-main

# Default credentials for each new database created. Overridden with --username and --password flags.
DB_USERNAME=root
DB_PASSWORD=
